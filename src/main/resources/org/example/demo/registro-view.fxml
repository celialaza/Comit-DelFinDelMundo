<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="600.0" maxWidth="800.0" minHeight="600.0" minWidth="800.0" prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.UI.RegistroController">

    <center>
        <VBox alignment="CENTER" maxHeight="550" maxWidth="750" spacing="20.0" style="-fx-background-color: rgba(44, 62, 80, 0.95); -fx-background-radius: 20px; -fx-padding: 30px;">

            <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="REGISTRO DE PARTIDAS" />

            <HBox alignment="CENTER" spacing="20.0">

                <Button fx:id="btnFiltroTodas" onAction="#filtrarTodas" prefHeight="50.0" prefWidth="160" styleClass="btn-decision-azul" text="TODAS" />

                <Button fx:id="btnFiltroVictoria" onAction="#filtrarVictorias" prefHeight="50.0" prefWidth="160" styleClass="btn-decision-azul" text="VICTORIAS" />
                <Button fx:id="btnFiltroDerrota" onAction="#filtrarDerrotas" prefHeight="50.0" prefWidth="160" styleClass="btn-decision-azul" text="DERROTAS" />

            </HBox>

            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaRegistro" HBox.hgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="150.0" text="COMITÉ" />
                        <TableColumn fx:id="colFecha" prefWidth="150.0" text="FECHA" />
                        <TableColumn fx:id="colResultado" prefWidth="100.0" text="RESULTADO" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <TextArea fx:id="areaDetalles" editable="false" prefWidth="250.0" style="-fx-control-inner-background: #263238; -fx-text-fill: white; -fx-font-size: 13px;" wrapText="true" />
            </HBox>

            <HBox alignment="CENTER" spacing="30.0">
                <Button fx:id="btnJugarDeNuevo" onAction="#jugarDeNuevo" prefHeight="50.0" prefWidth="220.0" styleClass="btn-decision-azul" text="JUGAR DE NUEVO" />
                <Button fx:id="btnSalir" onAction="#salir" prefHeight="50.0" prefWidth="220.0" styleClass="btn-decision-naranja" text="SALIR" />
            </HBox>
        </VBox>
    </center>

    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</BorderPane>
