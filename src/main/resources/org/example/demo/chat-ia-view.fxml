<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="450.0" prefWidth="400.0" spacing="15.0" styleClass="root-inventario" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.UI.ChatIAController">

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label fx:id="lblNombrePersonaje" styleClass="titulo-inventario" text="HABLANDO CON: ..." />

    <ScrollPane fx:id="scrollChat" fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-inventario" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="vBoxChat" spacing="10.0" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

    <HBox spacing="10.0">
        <children>
            <TextField fx:id="txtMensaje" onAction="#enviarMensaje" promptText="Haz tu pregunta..." styleClass="input-redondo" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEnviar" onAction="#enviarMensaje" styleClass="btn-decision-azul" text="ENVIAR" />
        </children>
    </HBox>

    <Button fx:id="btnCerrar" onAction="#cerrar" prefWidth="400.0" styleClass="boton-volver" text="Cerrar Comunicación" />

    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</VBox>
