<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="600.0" maxWidth="800.0" minHeight="600.0" minWidth="800.0" prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.UI.FinPartidaController">
    <center>
        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="25.0" style="-fx-background-color: rgba(44, 62, 80, 0.95); -fx-background-radius: 20px; -fx-border-radius: 20px; -fx-border-color: #B2EBF2; -fx-border-width: 2px; -fx-padding: 30px;">
            <children>
                <Label style="-fx-text-fill: #55FF55; -fx-font-size: 36px; -fx-font-weight: bold;" text="¡VICTORIA!" />
                <Label style="-fx-text-fill: white; -fx-font-size: 18px;" text="La colonia ha prosperado bajo tu mando." />

                <HBox alignment="CENTER" spacing="40.0">
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <ImageView fitHeight="30.0" fitWidth="30.0"><image><Image url="@heart.png" /></image></ImageView>
                                    <Label fx:id="lblFinalSalud" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" text="0%" />
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <ImageView fitHeight="30.0" fitWidth="30.0"><image><Image url="@happy-face.png" /></image></ImageView>
                                    <Label fx:id="lblFinalBienestar" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" text="0%" />
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <ImageView fitHeight="30.0" fitWidth="30.0"><image><Image url="@book.png" /></image></ImageView>
                                    <Label fx:id="lblFinalLegado" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" text="0%" />
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <ImageView fitHeight="30.0" fitWidth="30.0"><image><Image url="@settings.png" /></image></ImageView>
                                    <Label fx:id="lblFinalRecursos" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" text="0%" />
                                </HBox>
                            </children>
                        </VBox>

                        <ImageView fitHeight="200.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@imagenVictoria.png" />
                            </image>
                        </ImageView>
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <Button fx:id="btnVolver" onAction="#volverAlMenu" prefWidth="240.0" styleClass="btn-decision-naranja" text="Volver al Menú" />
                        <Button onAction="#registrarPartida" prefWidth="240.0" styleClass="btn-decision-azul" text="Registrar Partida" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</BorderPane>