<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="600.0" maxWidth="800.0" minHeight="600.0" minWidth="800.0" prefHeight="600.0" prefWidth="800.0"
            styleClass="root"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.demo.UI.FinPartidaController">

    <center>
        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="25.0"
              style="-fx-background-color: rgba(44, 62, 80, 0.95); -fx-background-radius: 20px; -fx-border-radius: 20px; -fx-border-color: #B2EBF2; -fx-border-width: 2px; -fx-padding: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 5);">

            <children>
                <Label text="¡Victoria!" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold; -fx-font-family: 'DejaVu Serif Bold';" />

                <Label text="¡Felicidades! Has logrado establecer una colonia próspera y sostenible." wrapText="true" maxWidth="500.0"
                       style="-fx-text-fill: #E0E0E0; -fx-font-size: 16px; -fx-text-alignment: center;" />

                <HBox alignment="CENTER" spacing="40.0">
                    <children>
                        <VBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@heart.png" /></image></ImageView>
                                    <Label text="60%" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@happy-face.png" /></image></ImageView>
                                    <Label text="75%" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@book.png" /></image></ImageView>
                                    <Label text="50%" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@settings.png" /></image></ImageView>
                                    <Label text="45%" style="-fx-text-fill: #55FF55; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </HBox>
                            </children>
                        </VBox>

                        <ImageView fitHeight="200.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@imagen_victoria.jpg" />
                            </image>
                        </ImageView>
                    </children>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </HBox>

                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <Button fx:id="btnVolver" onAction="#volverAlMenu" mnemonicParsing="false" prefWidth="240.0" styleClass="btn-decision-naranja" text="Volver al Menú" />
                        <Button onAction="#registrarPartida" mnemonicParsing="false" prefWidth="240.0" styleClass="btn-decision-azul" text="Registrar Partida" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
            </padding>
        </VBox>
    </center>
    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</BorderPane>