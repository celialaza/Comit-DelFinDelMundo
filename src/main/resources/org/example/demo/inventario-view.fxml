<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" styleClass="root-inventario" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.UI.InventarioController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label fx:id="title" styleClass="titulo-inventario" text="INVENTARIO DE LA COLONIA" />

    <ScrollPane fitToWidth="true" styleClass="scroll-inventario" VBox.vgrow="ALWAYS">
        <content>
            <TilePane fx:id="gridInventario" alignment="TOP_CENTER" hgap="15.0" prefColumns="3" style="-fx-background-color: transparent;" vgap="15.0">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </padding>
            </TilePane>
        </content>
    </ScrollPane>

    <Button fx:id="btnCerrarVentana" onAction="#cerrarVentana" styleClass="btn-decision-azul" text="Cerrar Inventario" />

    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</VBox>
