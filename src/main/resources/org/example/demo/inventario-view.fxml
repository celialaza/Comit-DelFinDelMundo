<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.TilePane?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="20.0" styleClass="root-inventario"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.demo.UI.InventarioController"
      prefWidth="500.0" prefHeight="400.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="INVENTARIO DE LA COLONIA" styleClass="titulo-inventario"/>

    <ScrollPane fitToWidth="true" styleClass="scroll-inventario" VBox.vgrow="ALWAYS">
        <content>
            <TilePane fx:id="gridInventario" hgap="15.0" vgap="15.0" prefColumns="3" alignment="TOP_CENTER"
                      style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </TilePane>
        </content>
    </ScrollPane>

    <Button text="Cerrar Inventario" onAction="#cerrarVentana" styleClass="btn-decision-azul"/>

    <stylesheets>
        <URL value="@estilos.css" />
    </stylesheets>
</VBox>